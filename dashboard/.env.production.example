# ============================================================
# DASHBOARD — CLOUDPANEL (self-host) PRODUCTION ŞABLONU
# Sunucuda bu dosyayı `.env.production` adıyla kopyalayıp doldurun.
# DİKKAT: NEXT_PUBLIC_* değişkenleri BUILD anında bundle'a gömülür →
# bu dosya `npm run build`'den ÖNCE hazır olmalı.
# ============================================================

# Dashboard domaini (NextAuth callback'leri buna göre üretilir)
NEXTAUTH_URL="https://gigax.cloud"
# openssl rand -base64 32  ile üret
NEXTAUTH_SECRET=""

# Google OAuth (Cloud Console). Authorized redirect URI:
#   https://gigax.cloud/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Backend bağlantısı
# - Sunucu tarafı (SSR/route handler) aynı makinede → localhost
# - Tarayıcı tarafı (NEXT_PUBLIC) → public api subdomaini
BACKEND_URL="http://127.0.0.1:3001"
BACKEND_INTERNAL_URL="http://127.0.0.1:3001"
NEXT_PUBLIC_BACKEND_URL="https://api.gigax.cloud"

# Admin / erişim
ADMIN_PASSWORD=""
ALLOWED_EMAILS="poyrazyapayzeka@gmail.com"
