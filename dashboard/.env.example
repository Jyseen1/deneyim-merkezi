# Backend
BACKEND_URL="http://localhost:3001"
BACKEND_INTERNAL_URL="http://localhost:3001"
NEXT_PUBLIC_BACKEND_URL="http://localhost:3001"

# Backend admin sifresi (NextAuth jwt callback'inde kullaniliyor)
ADMIN_PASSWORD=""
