# DASHBOARD ORTAM DEGISKENLERI - .env.local olarak kopyalayip doldurun

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# Google OAuth (Google Cloud Console > Credentials)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Yetkili e-postalar (virgulle ayirin)
