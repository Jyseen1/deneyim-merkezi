# BACKEND ORTAM DEGISKENLERI - .env olarak kopyalayip doldurun

# Veritabani (Neon PostgreSQL onerilir)
DATABASE_URL="postgresql://..."

# Redis (Upstash onerilir)
REDIS_URL="rediss://..."

# WhatsApp Business Cloud API
WA_ACCESS_TOKEN=""
WA_PHONE_NUMBER_ID=""
WA_WEBHOOK_VERIFY_TOKEN=""
WA_APP_SECRET=""
WA_BUSINESS_ACCOUNT_ID=""
STAFF_WA_PHONE=""

# WhatsApp Flow (rezervasyon formu)
WA_FLOW_ID=""
WA_FLOW_PRIVATE_KEY=""

# Uygulama
PORT=3001
NODE_ENV="development"

# Auth
JWT_SECRET=""
ADMIN_PASSWORD=""
ADMIN_EMAIL=""

# Rezervasyon ayarlari
APPROVAL_TIMEOUT_HOURS=2
REMINDER_HOURS_BEFORE=24
DEFAULT_DURATION_MINUTES=120

# Dashboard (CORS icin)
DASHBOARD_URL="http://localhost:3000"
