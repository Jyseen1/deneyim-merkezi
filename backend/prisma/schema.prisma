generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

model Visitor {
  id           String        @id @default(uuid())
  name         String
  phone        String        @unique
  email        String?
  createdAt    DateTime      @default(now())
  reservations Reservation[]

  @@map("visitors")
}

model Reservation {
  id              String            @id @default(uuid())
  visitor         Visitor           @relation(fields: [visitorId], references: [id])
  visitorId       String
  visitDate       DateTime          @db.Date
  startTime       String
  durationMinutes Int               @default(120)
  groupSize       Int               @default(1)
  note            String?
  status          ReservationStatus @default(PENDING_APPROVAL)
  waMessageId     String?
  approvedAt      DateTime?
  approvedBy      String?
  cancelledAt     DateTime?
  cancelReason    String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  notifications   Notification[]
  approvalToken   ApprovalToken?

  @@map("reservations")
}

enum ReservationStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
  CANCELLED
  COMPLETED
  NO_SHOW
}

model Slot {
  id          String   @id @default(uuid())
  slotDate    DateTime @db.Date
  startTime   String
  endTime     String
  isBlocked   Boolean  @default(false)
  blockReason String?
  createdAt   DateTime @default(now())

  @@unique([slotDate, startTime])
  @@map("slots")
}

model RecurringBlock {
  id        String   @id @default(uuid())
  dayOfWeek Int      // 0=Pazar … 6=Cumartesi (JS Date.getDay() ile uyumlu)
  startTime String   // "HH:MM"
  endTime   String
  reason    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("recurring_blocks")
}

model Staff {
  id           String  @id @default(uuid())
  name         String
  waPhone      String  @unique
  email        String  @unique
  role         String  @default("staff")
  isActive     Boolean @default(true)
  passwordHash String?

  @@map("staff")
}

model Notification {
  id            String      @id @default(uuid())
  reservation   Reservation @relation(fields: [reservationId], references: [id])
  reservationId String
  channel       String
  direction     String
  templateName  String?
  waMessageId   String?
  status        String      @default("sent")
  sentAt        DateTime    @default(now())

  @@map("notifications")
}

model Settings {
  id              String   @id @default("singleton")
  staffWaPhone    String?
  approvalEnabled Boolean  @default(true)
  reminderEnabled Boolean  @default(true)
  defaultDuration Int      @default(120)
  approvalTimeout Int      @default(2)
  workStart       String   @default("09:00")
  workEnd         String   @default("19:00")
  reminderHours   Int      @default(24)
  updatedAt       DateTime @updatedAt

  @@map("settings")
}

model ApprovalToken {
  id            String      @id @default(uuid())
  reservation   Reservation @relation(fields: [reservationId], references: [id])
  reservationId String      @unique
  token         String      @unique
  expiresAt     DateTime
  usedAt        DateTime?
  createdAt     DateTime    @default(now())

  @@map("approval_tokens")
}
